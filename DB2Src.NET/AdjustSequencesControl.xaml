<UserControl x:Name="userControl" x:Class="Db2Source.AdjustSequencesControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Db2Source"
             xmlns:local2="clr-namespace:Db2Source.DataSet;assembly=Db2SrcDataSet"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <DataTemplate x:Key="ListBoxItemTemplate1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition SharedSizeGroup="gr1"/>
                    <ColumnDefinition SharedSizeGroup="gr2"/>
                    <ColumnDefinition SharedSizeGroup="gr3"/>
                    <ColumnDefinition SharedSizeGroup="gr4"/>
                </Grid.ColumnDefinitions>
                <CheckBox Content="{Binding}"/>
                <!--<TextBlock Text="{Binding}" Grid.Column="1"/>-->
            </Grid>
        </DataTemplate>
    </UserControl.Resources>
    <DockPanel>
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button Content="一覧"/>
            </ToolBar>
        </ToolBarTray>
        <ListBox ItemTemplate="{DynamicResource ListBoxItemTemplate1}" Grid.IsSharedSizeScope="True" ItemsSource="{Binding Sequences, ElementName=userControl}">
        </ListBox>
    </DockPanel>
</UserControl>
